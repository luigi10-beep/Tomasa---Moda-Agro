# D1 Database
DATABASE_URL=tomasa-db
D1_DATABASE_ID=your-database-id-here

# Resend Email (Development)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=onboarding@resend.dev
RESEND_TO=email-da-silvana@gmail.com

